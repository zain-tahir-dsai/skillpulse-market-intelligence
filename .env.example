ENVIRONMENT=local
LOG_LEVEL=INFO

# API Credentials
ADZUNA_APP_ID=replace_with_your_adzuna_app_id
ADZUNA_APP_KEY=replace_with_your_adzuna_app_key

# API Configuration
REMOTEOK_BASE_URL=https://remoteok.com/api
REQUEST_TIMEOUT_SECONDS=30
MAX_RETRIES=3

# PostgreSQL Warehouse Database
POSTGRES_DB=skillpulse
POSTGRES_USER=skillpulse
POSTGRES_PASSWORD=replace_with_secure_password
POSTGRES_HOST=skillpulse-postgres
POSTGRES_PORT=5432

SKILLPULSE_DB_HOST=localhost
SKILLPULSE_DB_PORT=5433
SKILLPULSE_DB_NAME=skillpulse
SKILLPULSE_DB_USER=skillpulse
SKILLPULSE_DB_PASSWORD=skillpulse